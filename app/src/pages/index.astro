---
import "../styles/index.css";
import "../styles/globals.css";
import Modal from "../components/indexModal/modal.astro";
import { Image } from "astro:assets";
import IndexButton from "../components/indexButton.astro";

// image imports
import backgroundImgSrc from "/src/images/index/index.jpg";
import blogImgSrc from "/src/images/index/lotus.png";
import creationsImgSrc from "/src/images/index/cat.png";
import japanImgSrc from "/src/images/index/japan.png";
import portfolioImgSrc from "/src/images/index/lotus-transparent.png";
import resourcesImgSrc from "/src/images/index/tool.png";
import writingImgSrc from "/src/images/index/writing.png";
import detectiveImgSrc from "/src/images/index/detective.png";
import galleryImgSrc from "/src/images/index/tarepanda1.png";
import flappyImgSrc from "/src/images/index/kuchipatchi.png";
import neocitiesImgSrc from "/src/images/index/treble-cat.png";
import microblogImgSrc from "/src/images/index/heart-cookie.png";
import musicImgSrc from "/src/images/index/cd.png";
import flyingToroImgSrc from "/src/images/index/flyingtoro.png";
import startImgSrc from "/src/images/index/start.png";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>bunnyluv1</title>
    <link rel="icon" href="/src/images/index/index.jpg" type="image/jpg" />

    <script
      is:inline
      src="https://cdn.jsdelivr.net/npm/counterapi/dist/counter.browser.min.js"
    ></script>
    <script is:inline defer>
      // Counter is available as a global variable
      const counter = new Counter({ workspace: "kittenluv1" });

      counter
        .up("kittenluv1-visits")
        .then((result) => {
          console.log("Counter result:", result);
          document.getElementById("counter").textContent = result.data.up_count;
        })
        .catch((err) => console.error(err));
    </script>
  </head>
  <body>
    <div class="background-container">
      <Image
        src={backgroundImgSrc}
        alt=""
        loading="eager"
        fetchpriority="high"
        sizes="100vw"
        class="bg-img"
      />

      <Modal />

      <!-- BUTTONS -->
      <IndexButton
        img={blogImgSrc}
        imgStyle="width: 85%; height: auto; bottom: 25%;"
        text="nostalgiablog"
        href="/blog/2026"
        row={5}
        col={11}
      />
      <IndexButton
        img={creationsImgSrc}
        text="creations"
        href="/creations"
        row={1}
        col={1}
      />
      <IndexButton
        img={japanImgSrc}
        imgStyle="width: 70%; height: auto; "
        text="japan tv"
        href="https://youtu.be/3UTBZtwQMpI?si=sRSIXSru4suTvE5h"
        row={1}
        col={2}
      />
      <IndexButton
        img={portfolioImgSrc}
        text="portfolio"
        href="/portfolio"
        row={1}
        col={3}
      />
      <IndexButton
        img={resourcesImgSrc}
        text="resources"
        href="https://kittenluv1.neocities.org/resources"
        row={6}
        col={12}
      />
      <IndexButton
        img={writingImgSrc}
        text="writing"
        href="/writing"
        row={6}
        col={2}
      />
      <IndexButton
        img={detectiveImgSrc}
        imgStyle="height: 75%; bottom: 25%;"
        text="detective"
        href="https://introspec.itch.io/dimensional-detective"
        row={4}
        col={14}
      />
      <IndexButton
        img={galleryImgSrc}
        text="gallery"
        href="/gallery"
        row={6}
        col={7}
      />
      <IndexButton
        img={musicImgSrc}
        imgStyle="opacity: 0.9;"
        text="play"
        href="music"
        row={5}
        col={2}
      />
      <!-- <IndexButton
        img={flappyImgSrc}
        imgStyle="height: 70%; bottom: 25%;"
        text="flappypatchi"
        href="https://introspec.itch.io/flappypatchi"
        row={4}
        col={13}
      /> -->
      <!-- <IndexButton
        img={neocitiesImgSrc}
        text="neocities"
        href="https://kittenluv1.neocities.org/"
        row={6}
        col={11}
      /> -->
      <!-- <IndexButton
        img={microblogImgSrc}
        imgStyle="height: 50%;"
        text="microblog"
        href="/microblog"
        row={7}
        col={2}
      /> -->
    </div>

    <!-- WINDOWS XP FOOTER -->
    <footer>
      <Image src={startImgSrc} alt="" width="100" />
      <div id="copyright">
        <div>visits: <span id="counter"></span></div>
        <p>&copy; e**** 2024</p>
        <Image src={flyingToroImgSrc} alt="flying toro" width="100" />
      </div>
    </footer>
  </body>

  <script>
    // ========================== FOOTER GRADIENTS ========================= //
    const footer = document.querySelector("footer");
    const gradients = [
      `linear-gradient(
    rgb(31, 47, 134) 0px,
    rgb(49, 101, 196) 3%,
    rgb(54, 130, 229) 6%,
    rgb(68, 144, 230) 10%,
    rgb(56, 131, 229) 12%,
    rgb(43, 113, 224) 15%,
    rgb(38, 99, 218) 18%,
    rgb(35, 91, 214) 20%,
    rgb(34, 88, 213) 23%,
    rgb(33, 87, 214) 38%,
    rgb(36, 93, 219) 54%,
    rgb(37, 98, 223) 86%,
    rgb(36, 95, 220) 89%,
    rgb(33, 88, 212) 92%,
    rgb(29, 78, 192) 95%,
    rgb(25, 65, 165) 98%
  )`,
      `linear-gradient(
    rgb(255, 225, 235) 0px,
    rgb(255, 215, 225) 3%,
    rgb(255, 210, 220) 6%,
    rgb(255, 205, 215) 10%,
    rgb(255, 210, 220) 12%,
    rgb(255, 220, 230) 15%,
    rgb(255, 225, 235) 18%,
    rgb(255, 230, 240) 20%,
    rgb(255, 235, 245) 23%,
    rgb(255, 240, 245) 38%,
    rgb(255, 235, 240) 54%,
    rgb(255, 230, 235) 86%,
    rgb(255, 235, 240) 89%,
    rgb(255, 240, 245) 92%,
    rgb(255, 245, 250) 95%,
    rgb(255, 250, 255) 98%
  )`,
      `linear-gradient(
    rgb(150, 180, 255) 0px,
    rgb(170, 200, 255) 3%,
    rgb(180, 210, 255) 6%,
    rgb(190, 220, 255) 10%,
    rgb(185, 215, 255) 12%,
    rgb(175, 205, 255) 15%,
    rgb(165, 195, 255) 18%,
    rgb(160, 190, 255) 20%,
    rgb(158, 188, 255) 23%,
    rgb(157, 187, 255) 38%,
    rgb(160, 192, 255) 54%,
    rgb(162, 195, 255) 86%,
    rgb(160, 193, 255) 89%,
    rgb(157, 187, 255) 92%,
    rgb(150, 180, 240) 95%,
    rgb(140, 170, 220) 98%
  )`,
    ];

    // Track the current index instead of color names
    let currentIndex = 0;

    footer.addEventListener("click", () => {
      // Increment index and wrap around using modulo
      currentIndex = (currentIndex + 1) % gradients.length;
      footer.style.background = gradients[currentIndex];
    });
  </script>
</html>
