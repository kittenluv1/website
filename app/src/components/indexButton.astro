---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  img: ImageMetadata;
  imgStyle?: string;
  text: string;
  href: string;
  row: number;
  col: number;
}

const { img, imgStyle, text, href, row, col } = Astro.props;
---

<!-- use button for double click functionality (a does not provide this easily) -->
<button
  data-href={href}
  style={`grid-row-start: ${row}; grid-column-start: ${col};`}
>
  <Image
    src={img}
    alt={text}
    width="400"
    class="index-button-img"
    style={imgStyle}
  />
  <p>{text}</p>
</button>

<style>
  button {
    width: 100%;
    background-color: transparent;
    padding: 10%;
    aspect-ratio: 1/1;
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    border: none;
  }

  button:hover {
    cursor: default;
  }

  .index-button-img {
    position: absolute;
    border-radius: inherit;
    height: 60%;
    width: auto;
    bottom: 30%;
    opacity: 0.8;
  }

  p {
    position: absolute;
    margin: 0;
    bottom: 10%;
    font-size: 2vh;
    color: white;
    text-shadow:
      -1px -1px 0 #555555,
      1px -1px 0 #555555,
      -1px 1px 0 #555555,
      1px 1px 0 #555555,
      0px 0px 2px black;
  }
</style>

<script>
  document
    .querySelectorAll<HTMLButtonElement>("button[data-href]")
    .forEach((btn) => {
      const href = btn.dataset.href;
      if (!href) return;

      if (href == "music") {
        btn.addEventListener("dblclick", () => {
          window.dispatchEvent(new CustomEvent("toggle-modal"));
        });
        return;
      }

      btn.addEventListener("dblclick", () => {
        href.startsWith("http")
          ? window.open(href)
          : (window.location.href = href);
      });
    });
</script>
